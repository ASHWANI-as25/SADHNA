# ⚠️ DO NOT COMMIT THIS FILE - CONTAINS SENSITIVE DATA
# Make sure .env.local is in .gitignore (it should be already)

# 🔐 Supabase Configuration
# Get these from: https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 🤖 Groq API Configuration (for AI habit predictions)
# Get this from: https://console.groq.com → API Keys
VITE_GROQ_API_KEY=your-groq-api-key-here

# 📱 OAuth Configuration (Optional - for social login)
# These are usually configured in Supabase OAuth settings
# VITE_GOOGLE_CLIENT_ID=your-google-client-id
# VITE_GITHUB_CLIENT_ID=your-github-client-id
# VITE_LINKEDIN_CLIENT_ID=your-linkedin-client-id
