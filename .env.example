# ====================================
# SADHNA PROJECT - ENVIRONMENT VARIABLES
# ====================================

# Copy this file to .env.local and fill in your credentials

# ---- SUPABASE CONFIGURATION ----
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ---- GROQ AI CONFIGURATION ----
# Get from: https://console.groq.com
VITE_GROQ_API_KEY=your-groq-api-key

# ---- OAUTH PROVIDERS ----
# Get these from respective provider dashboards:
# - Google: https://console.cloud.google.com/
# - GitHub: https://github.com/settings/developers
# - LinkedIn: https://www.linkedin.com/developers/apps

VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GITHUB_CLIENT_ID=your-github-client-id
VITE_GITHUB_CLIENT_SECRET=your-github-client-secret

VITE_LINKEDIN_CLIENT_ID=your-linkedin-client-id
VITE_LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# ====================================
# OPTIONAL SETTINGS
# ====================================

# Backend API URL (for OAuth callbacks and advanced features)
VITE_API_URL=http://localhost:3000/api

# Feature flags
VITE_ENABLE_OAUTH=false
VITE_ENABLE_LIVE_PROCTORING=true
VITE_ENABLE_CODE_EXECUTION=true
VITE_DEMO_MODE=false
